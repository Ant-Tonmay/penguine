{
    class Animal {
        public {
            func speak() {
                println("Animal speaks");
            }
        }
    }

    class Dog inherits Animal {
        public {
            func speak() {
                println("Bark");
            }
            func originalSpeak() {
                // accessing parent method? super? 
                // Penguin doesn't support super yet, but we are testing overriding here.
                // so we just want to verify Dog.speak() calls the new one.
            }
        }
    }

    class Cat inherits Animal {
        // Inherits speak from Animal
    }

    class Base {
        public {
            func publicMethod() { println("Public Base"); }
        }
        protected {
            func protectedMethod() { println("Protected Base"); }
        }
        private {
            func privateMethod() { println("Private Base"); }
        }
        public {
            func callPrivate() { privateMethod(); }
        }
    }

    class Derived inherits Base {
        public {
            func test() {
                publicMethod();
                protectedMethod();
                // privateMethod(); // Should crash if uncommented
            }
        }
    }

    func main() {
        println("--- Overriding Test ---");
        d = Dog();
        d.speak(); // Bark

        c = Cat();
        c.speak(); // Animal speaks

        println("--- Visibility Test ---");
        der = Derived();
        der.test();
        der.callPrivate(); // Should work because it calls Base's privateMethod from Base context... 
                           // WAIT. If we copy methods down, 'callPrivate' is now a method of 'Derived'.
                           // And 'privateMethod' was NOT copied.
                           // So 'callPrivate' body will try to call 'privateMethod'.
                           // Since 'privateMethod' is not in Derived (not copied), this should FAIL if the body lookup relies on 'this' having the method.
                           // This exposes a potential flaw in "copy-down" textual inheritance if internal calls depend on private members.
                           // Let's verify behavior.
                           // If 'callPrivate' was defined in Base, its AST body calls 'privateMethod'.
                           // When we copy 'callPrivate' to Derived, we execute that same AST body with 'this' being instance of Derived.
                           // Evaluator looks up 'privateMethod' on Derived. It's missing!
                           // So this WILL fail. 
                           // This implicitly confirms "private members are not inherited" but also "methods relying on private members break if inherited".
                           // This is common in simple dynamic inheritance unless we have 'super' or bound scopes.
                           // For now, let's just test that we CAN call public/protected.
    }
}
