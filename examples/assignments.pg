{
    func main(){
        a = 10;
        b = 5;

        c = a+b;
        c+=1;
        println(c);
        d = 0;
        d+=a;
        println(d);
        e = 20;
        e/=a;
        println(e);

        f = 1;
        f*=a;
        println(f);

        g = 1;
        h = 0;
        h|=g;
        println(h);
        m=0;
        g &= m;
        println(g);
        
    }
}