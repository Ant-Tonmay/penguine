{
    func main(){
        brr = fixed(5);
        for(i = 0; i < 5; i = i + 1){
            brr[i] = i;
            print(brr[i]);
        }

        drr = fixed(3, 0);
        print(drr[0]);
        print(drr[1]);
        print(drr[2]);

        crr = [];
        for(i = 0; i < 5; i = i + 1){
            crr.push(i);
        }
        print(crr[0]);
        print(crr[1]);
        print(crr[4]);
    }
}
